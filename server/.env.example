# ===========================================
# Kappa Pi Kappa Payment Server Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Stripe Configuration
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# PayPal/Venmo Configuration
# Get these from https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=xxx
PAYPAL_CLIENT_SECRET=xxx
PAYPAL_WEBHOOK_ID=xxx

# Database Configuration
# Path to SQLite database file (relative to server directory)
DATABASE_URL=./db/donors.db

# Email Configuration (for sending receipts)
# Gmail example - you may need to use an App Password
# https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ===========================================
# Stripe Product/Price IDs
# ===========================================
# Create these in your Stripe Dashboard under Products
# and add the price IDs here for reference

# Monthly Donation Plans
# STRIPE_PRICE_MONTHLY_10=price_xxx
# STRIPE_PRICE_MONTHLY_25=price_xxx
# STRIPE_PRICE_MONTHLY_50=price_xxx
# STRIPE_PRICE_MONTHLY_75=price_xxx
# STRIPE_PRICE_MONTHLY_100=price_xxx

# Dollar-a-Day Plans
# STRIPE_PRICE_DAD_5YR=price_xxx    # $30.42/month
# STRIPE_PRICE_DAD_7YR=price_xxx    # $60.83/month
# STRIPE_PRICE_DAD_10YR=price_xxx   # $91.25/month
